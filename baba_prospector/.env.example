# ─────────────────────────────────────────────
# Baba Prospector — Variables de entorno
# Copiá este archivo como .env y completá los valores
# ─────────────────────────────────────────────

# Token del bot de Telegram
# Obtener en: @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# API key de Groq (transcripción + LLM)
# Obtener en: https://console.groq.com/keys
GROQ_API_KEY=

# ID del Google Spreadsheet
# Es la parte larga de la URL: docs.google.com/spreadsheets/d/[ESTE_ID]/edit
GOOGLE_SHEETS_ID=

# Path al JSON de credenciales del Service Account de Google
# Ver docs/setup_sheets.md para instrucciones de creación
GOOGLE_CREDENTIALS_JSON=./credentials.json
